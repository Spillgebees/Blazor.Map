@namespace Spillgebees.Blazor.Map.Components
@inherits StyledContentMapControlBase

<div @ref="_placeholderReference" class="sgb-map-custom-control-placeholder" hidden>
    <div id="@_contentId" @ref="_contentReference" class="sgb-map-custom-control-content" hidden>
        <div class="@GroupClass" aria-label="@Label">
            <button type="button"
                    class="@ButtonClass"
                    aria-label="@Label"
                    title="@Title"
                    disabled="@Disabled"
                    @onclick="OnClick">
                @if (Icon is not null)
                {
                    <span class="sgb-map-control-icon" aria-hidden="true">
                        @Icon
                    </span>
                }
                @if (!string.IsNullOrWhiteSpace(Text))
                {
                    <span class="sgb-map-control-text">@Text</span>
                }
            </button>
        </div>
    </div>
</div>
