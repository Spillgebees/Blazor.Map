<Project Sdk="Microsoft.NET.Sdk.Razor">
  <Import Project="../General.targets" />

  <PropertyGroup>
    <Authors>Jason Rebelo Neves (igotinfected)</Authors>
    <Company>Spillgebees</Company>
    <Description>Spillgebees.Blazor.Map is a Blazor map component powered by MapLibre GL JS.</Description>
    <PackageTags>blazor, blazor-wasm, blazor-server, maplibre, maplibre-gl, map</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>spillgebees.png</PackageIcon>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\assets\spillgebees.png" Pack="true" PackagePath="" />
    <None Include="README.md" Pack="true" PackagePath="" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Spillgebees.Blazor.Map.Tests" />
  </ItemGroup>

  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="BlazorComponentUtilities" />
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference
      Include="..\Spillgebees.Blazor.Map.Assets\Spillgebees.Blazor.Map.Assets.csproj"
      ReferenceOutputAssembly="false"
      Private="false"
    />
  </ItemGroup>

  <!--
    This target re-evaluates the wwwroot glob at target execution time, after the Assets
    project has built but before the SDK resolves static web assets.
  -->
  <Target
    Name="IncludeViteBuildOutputs"
    BeforeTargets="ResolveProjectStaticWebAssets"
    DependsOnTargets="ResolveProjectReferences"
  >
    <ItemGroup>
      <Content Remove="wwwroot\**" />
      <Content
        Include="wwwroot\**"
        Condition="Exists('$(MSBuildProjectDirectory)\wwwroot')"
        ExcludeFromSingleFile="true"
        CopyToPublishDirectory="PreserveNewest"
        Exclude="$(DefaultItemExcludes);$(DefaultExcludesInProjectFolder)"
      />
      <_ContentIncludedByDefault Remove="wwwroot\**" />
      <_ContentIncludedByDefault Include="wwwroot\**" Condition="Exists('$(MSBuildProjectDirectory)\wwwroot')" />
    </ItemGroup>
  </Target>
</Project>
