@using Spillgebees.Blazor.Map.Components
@using Spillgebees.Blazor.Map.Models
@using Spillgebees.Blazor.Map.Models.Controls
@using Spillgebees.Blazor.Map.Models.Layers
@using Spillgebees.Blazor.Map.Models.Popups

<div>
    <h3>Basic map component usage</h3>
    <CodeSnippet Code="@Code">
        <Component>
            <SgbMap MapOptions="@_mapOptions"
                    ControlOptions="@_mapControlOptions"
                    Markers="@_markers"
                    Circles="@_circles"
                    Polylines="@_polylines" />
        </Component>
    </CodeSnippet>
</div>

@code {
    private const string Code =
@"<SgbMap MapOptions=""@_mapOptions""
        ControlOptions=""@_mapControlOptions""
        Markers=""@_markers""
        Circles=""@_circles""
        Polylines=""@_polylines"" />";

    private readonly MapOptions _mapOptions = new(
        Center: new Coordinate(49.751667, 6.101667),
        Zoom: 9,
        FitBoundsOptions: new FitBoundsOptions(["polyline-1", "polyline-2"], Padding: new Point(100, 100))
    );

    private readonly MapControlOptions _mapControlOptions = MapControlOptions.Default with
    {
        Center = new CenterControlOptions(
            Enable: true,
            Position: ControlPosition.TopRight,
            Center: new Coordinate(0, 0),
            Zoom: 0,
            FitBoundsOptions: new FitBoundsOptions(["polyline-1", "polyline-2"], Padding: new Point(100, 100)))
    };

    private readonly List<Marker> _markers =
    [
        new("marker-1", new Coordinate(49.5999673, 6.1342483), "Luxembourg")
    ];

    private readonly List<Circle> _circles =
    [
        new(
            "circle-1",
            new Coordinate(49.751496994, 6.106166242),
            StrokeColor: "#C41039",
            StrokeWidth: 2,
            Color: "white",
            Opacity: 1,
            Popup: new PopupOptions("Circle 1", Trigger: PopupTrigger.Hover)),
        new(
            "circle-2",
            new Coordinate(49.7912, 6.1188),
            StrokeColor: "#C41039",
            StrokeWidth: 2,
            Color: "white",
            Opacity: 1),
        new(
            "circle-3",
            new Coordinate(49.808996764, 6.100999596),
            StrokeColor: "#C41039",
            StrokeWidth: 2,
            Color: "white",
            Opacity: 1),
        new(
            "circle-4",
            new Coordinate(49.842163298, 6.104332916),
            StrokeColor: "#C41039",
            StrokeWidth: 2,
            Color: "white",
            Opacity: 1)
    ];

    private readonly List<Polyline> _polylines =
    [
        new(
            "polyline-1",
            [
                new Coordinate(49.751496994, 6.106166242),
                new Coordinate(49.7912, 6.1188),
                new Coordinate(49.808996764, 6.100999596),
                new Coordinate(49.842163298, 6.104332916)
            ],
            Color: "#C41039",
            Width: 6),
        new(
            "polyline-2",
            [
                new Coordinate(50.751496994, 6.106166242),
                new Coordinate(50.7912, 6.1188),
                new Coordinate(50.808996764, 6.100999596),
                new Coordinate(50.842163298, 6.104332916)
            ],
            Color: "#C41039",
            Width: 6)
    ];
}
