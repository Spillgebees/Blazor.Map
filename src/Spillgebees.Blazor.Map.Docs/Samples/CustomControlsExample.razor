@using Spillgebees.Blazor.Map.Components
@using Spillgebees.Blazor.Map.Components.Layers
@using Spillgebees.Blazor.Map.Models
@using Spillgebees.Blazor.Map.Models.Controls
@using Spillgebees.Blazor.Map.Models.Legends

<SgbMap MapOptions="@_mapOptions"
        Height="450px"
        Width="100%"
        @ref="_map">
    <MapControls>
        <MapNavigationControl Position="ControlPosition.TopRight" Order="10" />
        <MapFullscreenControl Position="ControlPosition.TopRight" Order="20" />
        <MapCenterControl Position="ControlPosition.TopLeft" Order="5" />
        <MapScaleControl Position="ControlPosition.BottomLeft" Order="5" />

        <MapActionControl Id="station-focus"
                          Position="ControlPosition.TopLeft"
                          Order="15"
                          Label="@FocusActionLabel"
                          Title="@FocusActionLabel"
                          Text="@FocusText"
                          OnClick="FocusNextStationAsync">
            <Icon>
                <svg class="docs-station-focus-icon"
                     viewBox="0 0 24 24"
                     aria-hidden="true"
                     focusable="false">
                    <path d="M12 21s6-5.1 6-11a6 6 0 1 0-12 0c0 5.9 6 11 6 11Z"
                          fill="none"
                          stroke="currentColor"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2" />
                    <circle cx="12"
                            cy="10"
                            r="2"
                            fill="currentColor" />
                </svg>
            </Icon>
        </MapActionControl>

        <MapLegendControl Id="network-legend"
                          Position="ControlPosition.TopRight"
                          Order="50"
                          Title="Network layers"
                          Collapsible="true"
                          InitiallyOpen="true"
                          Definition="@_legendDefinition" />
    </MapControls>

    <MapSources>
        <GeoJsonSource Id="network"
                       Data="@NetworkData">
            <LineLayer Id="metro-line"
                       Color="@("#2563eb")"
                       Width="4" />
            <CircleLayer Id="station-layer"
                         Color="@("#f97316")"
                         Radius="5"
                         StrokeColor="@("#ffffff")"
                         StrokeWidth="2" />
        </GeoJsonSource>
    </MapSources>
</SgbMap>

@code {
    private readonly MapOptions _mapOptions = new(
        Style: MapStyle.OpenFreeMap.Liberty,
        Center: new Coordinate(49.6117, 6.1319),
        Zoom: 12
    );

    private readonly StationFeature[] _stations =
    [
        new("Central Station", [6.1319, 49.6117]),
        new("North Station", [6.1600, 49.6200]),
        new("West Station", [6.0950, 49.6030]),
    ];

    private SgbMap? _map;
    private int _nextStationIndex;
    private string? _focusedStationName;

    private StationFeature NextStation => _stations[_nextStationIndex];

    private string FocusLabel => _focusedStationName is null ? NextStation.Name : $"Focused {_focusedStationName}";

    private string FocusActionLabel => $"Focus {NextStation.Name}";

    private string FocusText => $"Focus station: {FocusLabel}";

    private object NetworkData => new
    {
        type = "FeatureCollection",
        features = CreateNetworkFeatures(),
    };

    private readonly MapLegendDefinition _legendDefinition =
        new(
            [
                new MapLegendSectionDefinition(
                    "Transit",
                    [
                        new MapLegendItemDefinition(
                            Id: "metro-lines",
                            Label: "Metro lines",
                            Targets:
                            [
                                new MapLegendTargetDefinition(styleId: "sgb-liberty", layerIds: ["metro-line"]),
                            ],
                            IsVisibleByDefault: true,
                            IsToggleable: true
                        ),
                        new MapLegendItemDefinition(
                            Id: "stations",
                            Label: "Stations",
                            Targets:
                            [
                                new MapLegendTargetDefinition(styleId: "sgb-liberty", layerIds: ["station-layer"]),
                            ],
                            IsVisibleByDefault: true,
                            IsToggleable: true
                        ),
                    ]
                ),
            ]
        );

    private object[] CreateNetworkFeatures()
    {
        var features = new List<object>
        {
            new
            {
                type = "Feature",
                properties = new { name = "Line A", kind = "line" },
                geometry = new
                {
                    type = "LineString",
                    coordinates = new[]
                    {
                        new[] { 6.0950, 49.6030 },
                        new[] { 6.1319, 49.6117 },
                        new[] { 6.1600, 49.6200 },
                    },
                },
            },
        };

        features.AddRange(_stations.Select(CreateStationFeature));

        return [.. features];
    }

    private static object CreateStationFeature(StationFeature station) =>
        new
        {
            type = "Feature",
            properties = new { name = station.Name, kind = "station" },
            geometry = new
            {
                type = "Point",
                coordinates = station.Coordinates,
            },
        };

    private async Task FocusNextStationAsync()
    {
        var station = NextStation;
        _focusedStationName = station.Name;
        _nextStationIndex = (_nextStationIndex + 1) % _stations.Length;

        if (_map is not null)
        {
            await _map.FlyToAsync(station.ToCoordinate(), zoom: 14);
        }
    }

    private sealed record StationFeature(string Name, double[] Coordinates)
    {
        public Coordinate ToCoordinate() => new(Coordinates[1], Coordinates[0]);
    }
}
