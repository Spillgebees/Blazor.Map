@using Spillgebees.Blazor.Map.Components
@using Spillgebees.Blazor.Map.Components.Layers
@using Spillgebees.Blazor.Map.Models
@using Spillgebees.Blazor.Map.Models.Controls
@using Spillgebees.Blazor.Map.Models.Legends

<SgbMap MapOptions="@_mapOptions"
        Height="450px"
        Width="100%">
    <MapCustomControls>
        <MapNavigationControl Position="ControlPosition.TopRight" Order="10" />
        <MapFullscreenControl Position="ControlPosition.TopRight" Order="20" />
        <MapGeolocateControl Position="ControlPosition.TopRight" Order="30" TrackUser="true" />
        <MapTerrainControl Position="ControlPosition.TopRight" Order="40" />
        <MapCenterControl Position="ControlPosition.TopLeft" Order="5" />
        <MapScaleControl Position="ControlPosition.BottomLeft" Order="5" />

        <MapCustomControl Id="refresh-map" Position="ControlPosition.TopLeft" Order="10" Class="docs-map-button-control">
            <div class="sgb-map-ctrl-group">
                <button type="button" title="Refresh map data" @onclick="RefreshData">
                    <img src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Cpath fill='black' d='M17.7 6.3A8 8 0 1 0 20 12h-2a6 6 0 1 1-1.76-4.24L13 11h8V3l-3.3 3.3Z'/%3E%3C/svg%3E"
                         width="18"
                         height="18"
                         alt="" />
                    <span class="visually-hidden">Refresh map data</span>
                </button>
            </div>
        </MapCustomControl>

        <MapCustomControl Id="network-mode" Position="ControlPosition.TopLeft" Order="20" Class="docs-map-button-control">
            <div class="sgb-map-ctrl-group">
                <button type="button" title="Network mode" @onclick="ToggleNetworkMode">
                    <svg width="18" height="18" viewBox="0 0 24 24" role="img" aria-label="Network mode">
                        <path fill="currentColor" d="M12 3 3 8l9 5 9-5-9-5Zm0 7.7L7.1 8 12 5.3 16.9 8 12 10.7ZM5 10.2l7 3.9 7-3.9v2.3l-7 3.9-7-3.9v-2.3Zm0 4 7 3.9 7-3.9v2.3l-7 3.9-7-3.9v-2.3Z" />
                    </svg>
                </button>
            </div>
        </MapCustomControl>

        <MapCustomControl Id="view-tools" Position="ControlPosition.TopLeft" Order="30" Class="docs-map-button-control">
            <div class="sgb-map-ctrl-group">
                <button type="button" title="Zoom to network" @onclick="ZoomToNetwork">⌖</button>
                <button type="button" title="Show details" @onclick="ToggleDetails">i</button>
            </div>
        </MapCustomControl>

        <MapCustomControl Id="live-toggle" Position="ControlPosition.BottomLeft" Order="10" Class="docs-map-toggle-control">
            <label class="docs-map-toggle">
                <input type="checkbox" @bind="_liveUpdatesEnabled" />
                <span>Live updates</span>
            </label>
        </MapCustomControl>

        <MapCustomControl Id="network-panel" Position="ControlPosition.BottomRight" Order="10" Class="docs-map-panel-control">
            <section class="docs-map-panel">
                <strong>Network summary</strong>
                <p>@_statusMessage</p>
                <p>Mode: @(_networkModeEnabled ? "network" : "standard")</p>
            </section>
        </MapCustomControl>

        <MapLegendControl Id="network-legend"
                          Position="ControlPosition.TopRight"
                          Order="50"
                          Title="Network layers"
                          Collapsible="true"
                          InitiallyOpen="true"
                          Definition="@_legendDefinition" />
    </MapCustomControls>

    <GeoJsonSource Id="network"
                   Data="@_networkData">
        <LineLayer Id="metro-line"
                   Color="@("#2563eb")"
                   Width="4" />
        <CircleLayer Id="station-layer"
                     Color="@("#f97316")"
                     Radius="5"
                     StrokeColor="@("#ffffff")"
                     StrokeWidth="2" />
    </GeoJsonSource>
</SgbMap>

@code {
    private readonly MapOptions _mapOptions = new(
        Style: MapStyle.OpenFreeMap.Liberty,
        Center: new Coordinate(49.6117, 6.1319),
        Zoom: 12
    );

    private bool _liveUpdatesEnabled = true;
    private bool _networkModeEnabled;
    private bool _detailsVisible;
    private string _statusMessage = "Ready";

    private readonly MapLegendDefinition _legendDefinition =
        new(
            [
                new MapLegendSectionDefinition(
                    "Transit",
                    [
                        new MapLegendItemDefinition(
                            Id: "metro-lines",
                            Label: "Metro lines",
                            Targets:
                            [
                                new MapLegendTargetDefinition(
                                    styleId: "sgb-liberty",
                                    layerIds: ["metro-line"])
                            ],
                            IsVisibleByDefault: true,
                            IsToggleable: true
                        ),
                        new MapLegendItemDefinition(
                            Id: "stations",
                            Label: "Stations",
                            Targets:
                            [
                                new MapLegendTargetDefinition(
                                    styleId: "sgb-liberty",
                                    layerIds: ["station-layer"])
                            ],
                            IsVisibleByDefault: true,
                            IsToggleable: true
                        )
                    ])
            ]
        );

    private static readonly object _networkData = new
    {
        type = "FeatureCollection",
        features = new object[]
        {
            new
            {
                type = "Feature",
                properties = new { name = "Line A" },
                geometry = new
                {
                    type = "LineString",
                    coordinates = new[]
                    {
                        new[] { 6.0950, 49.6030 },
                        new[] { 6.1319, 49.6117 },
                        new[] { 6.1600, 49.6200 },
                    },
                },
            },
            new
            {
                type = "Feature",
                properties = new { name = "Central Station" },
                geometry = new
                {
                    type = "Point",
                    coordinates = new[] { 6.1319, 49.6117 },
                },
            },
            new
            {
                type = "Feature",
                properties = new { name = "North Station" },
                geometry = new
                {
                    type = "Point",
                    coordinates = new[] { 6.1600, 49.6200 },
                },
            },
        },
    };

    private void RefreshData()
    {
        _statusMessage = "Data refreshed from Blazor state";
    }

    private void ToggleNetworkMode()
    {
        _networkModeEnabled = !_networkModeEnabled;
        _statusMessage = _networkModeEnabled ? "Network mode enabled" : "Network mode disabled";
    }

    private void ZoomToNetwork()
    {
        _statusMessage = "Zoom action handled by Blazor";
    }

    private void ToggleDetails()
    {
        _detailsVisible = !_detailsVisible;
        _statusMessage = _detailsVisible ? "Details visible" : "Details hidden";
    }
}
