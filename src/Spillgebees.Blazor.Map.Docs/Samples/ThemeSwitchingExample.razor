<div class="sample-btn-row">
    <button type="button" class="sample-btn @(_theme == MapTheme.Light ? "active" : "")" aria-pressed="@(_theme == MapTheme.Light)" @onclick="@(() => _theme = MapTheme.Light)">Light</button>
    <button type="button" class="sample-btn @(_theme == MapTheme.Dark ? "active" : "")" aria-pressed="@(_theme == MapTheme.Dark)" @onclick="@(() => _theme = MapTheme.Dark)">Dark</button>
</div>

<SgbMap MapOptions="@_mapOptions"
        Theme="@_theme"
        Markers="@_markers"
        Height="400px"
        Width="100%">
    <MapControls>
        <MapNavigationControl />
    </MapControls>
</SgbMap>

@code {
    private MapTheme _theme = MapTheme.Light;

    private readonly MapOptions _mapOptions = new(
        Center: new Coordinate(49.6117, 6.1319),
        Zoom: 12,
        Style: MapStyle.OpenFreeMap.Liberty
    );

    private readonly List<Marker> _markers =
    [
        new(
            "marker-lux-city",
            new Coordinate(49.6117, 6.1319),
            Title: "Luxembourg City",
            Popup: PopupOptions.FromRawHtml(
                "<strong>Luxembourg City</strong><br>Hover to see themed popup styling.",
                PopupTrigger.Hover
            )
        )
    ];
}
