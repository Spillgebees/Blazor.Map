@using Spillgebees.Blazor.Map.Components
@using Spillgebees.Blazor.Map.Components.Layers
@using Spillgebees.Blazor.Map.Models
@using Spillgebees.Blazor.Map.Models.Events
@using Spillgebees.Blazor.Map.Models.Expressions
@using Spillgebees.Blazor.Map.Models.Legends
@using Spillgebees.Blazor.Map.Models.TrackedData
@using Spillgebees.Blazor.Map.Models.TrackedEntities
@using Spillgebees.Blazor.Map.Docs.Samples.TrainTracking

<style>
    @@import url("https://fonts.googleapis.com/css2?family=Martian+Mono:wght@400&family=DM+Sans:wght@400;500;600;700&display=swap");

    .train-showcase-map {
        overflow: hidden;
        border-radius: 22px;
        border: 1px solid rgba(148, 163, 184, 0.25);
        background: rgba(255, 255, 255, 0.88);
        backdrop-filter: blur(10px);
    }

    /* legend layout */

    .train-showcase-map .sgb-map-legend-content {
        font-family: "DM Sans", sans-serif;
        font-size: 14px;
        line-height: 1.4;
    }

    .train-showcase-map .sgb-map-legend-section-title {
        font-family: "Martian Mono", monospace;
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        font-weight: 400;
    }

    .train-showcase-map .sgb-map-legend-title {
        font-family: "DM Sans", sans-serif;
        font-size: 15px;
        font-weight: 700;
        letter-spacing: -0.01em;
    }

    .train-showcase-map .train-overlay-legend-content {
        gap: 12px;
    }

    .train-showcase-map .train-overlay-legend-item {
        display: grid;
        grid-template-columns: 44px minmax(0, 1fr);
        gap: 10px;
        align-items: center;
        padding: 8px;
        border-radius: 12px;
        cursor: pointer;
        transition: background 0.15s;
        user-select: none;
    }

    .train-showcase-map .train-overlay-legend-item:hover {
        background: var(--sgb-map-ctrl-bg-hover);
    }

    .train-showcase-map .train-overlay-legend-copy {
        display: grid;
        gap: 2px;
        min-width: 0;
    }

    /* swatch container */

    .train-showcase-map .train-overlay-swatch {
        position: relative;
        display: grid;
        place-items: center;
        width: 44px;
        height: 44px;
        border-radius: 10px;
    }

    .train-showcase-map .train-overlay-swatch-art {
        position: absolute;
        inset: 0;
        border-radius: inherit;
        overflow: hidden;
        transition: opacity 0.25s, filter 0.25s;
    }

    .train-showcase-map .train-overlay-swatch-art > span {
        position: absolute;
    }

    /* checkbox badge */

    .train-showcase-map .train-overlay-swatch-badge {
        position: absolute;
        bottom: -2px;
        right: -2px;
        width: 16px;
        height: 16px;
        border-radius: 999px;
        background: #2563eb;
        border: 2px solid #fff;
        z-index: 2;
        display: grid;
        place-items: center;
        will-change: transform;
        backface-visibility: hidden;
        transition: background 0.2s, transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .train-showcase-map .train-overlay-swatch-badge::before,
    .train-showcase-map .train-overlay-swatch-badge::after {
        content: "";
        position: absolute;
        transition: opacity 0.15s;
    }

    /* checkmark (visible when active) */
    .train-showcase-map .train-overlay-swatch-badge::after {
        width: 6px;
        height: 3px;
        margin-top: -1px;
        border-left: 1.5px solid #fff;
        border-bottom: 1.5px solid #fff;
        transform: rotate(-45deg);
    }

    /* cross arm 1 (visible when inactive) */
    .train-showcase-map .train-overlay-swatch-badge::before {
        width: 7px;
        height: 1.5px;
        background: #fff;
        border-radius: 1px;
        transform: rotate(45deg);
        opacity: 0;
    }

    .train-showcase-map .train-overlay-legend-item input {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
    }

    /* disabled / off state */

    .train-showcase-map .train-overlay-legend-item[data-active="false"] .sgb-map-legend-item-label {
        color: #94a3b8;
    }

    .train-showcase-map .train-overlay-legend-item[data-active="false"] .sgb-map-legend-item-description {
        color: #cbd5e1;
    }

    .train-showcase-map .train-overlay-legend-item[data-active="false"] .train-overlay-swatch-badge {
        background: #94a3b8;
    }

    /* hide checkmark, show cross */
    .train-showcase-map .train-overlay-legend-item[data-active="false"] .train-overlay-swatch-badge::after {
        width: 7px;
        height: 1.5px;
        margin-top: 0;
        border: none;
        background: #fff;
        border-radius: 1px;
        transform: rotate(-45deg);
    }

    .train-showcase-map .train-overlay-legend-item[data-active="false"] .train-overlay-swatch-badge::before {
        opacity: 1;
    }

    /* swatch backgrounds */

    .train-showcase-map .train-overlay-swatch-stations,
    .train-showcase-map .train-overlay-swatch-platforms,
    .train-showcase-map .train-overlay-swatch-routes,
    .train-showcase-map .train-overlay-swatch-tracks,
    .train-showcase-map .train-overlay-swatch-tram,
    .train-showcase-map .train-overlay-swatch-lifecycle,
    .train-showcase-map .train-overlay-swatch-infrastructure {
        background: linear-gradient(180deg, rgba(241, 245, 249, 0.9), rgba(226, 232, 240, 0.7));
    }

    .train-showcase-map .train-overlay-swatch-3d-buildings {
        background: linear-gradient(180deg, rgba(241, 245, 249, 0.9), rgba(226, 232, 240, 0.7));
    }

    /* inline SVG swatch */
    .train-showcase-map .train-overlay-swatch-svg {
        width: 100%;
        height: 100%;
    }

    .train-showcase-map .b-roof { fill: #d4d6d9; stroke: #b8babe; stroke-width: 0.5; }
    .train-showcase-map .b-left { fill: #a8aab0; stroke: #9a9ca2; stroke-width: 0.5; }
    .train-showcase-map .b-right { fill: #bcbec4; stroke: #9a9ca2; stroke-width: 0.5; }

    .train-showcase-map .p-roof { fill: #c4b8e8; stroke: #a090d0; stroke-width: 0.5; }
    .train-showcase-map .p-left { fill: #9888c0; }
    .train-showcase-map .p-right { fill: #b0a0d8; }

    .train-showcase-map .sig-post { stroke: #606068; stroke-width: 3; stroke-linecap: round; }
    .train-showcase-map .sig-head { fill: #404048; stroke: #353540; stroke-width: 0.75; stroke-linejoin: round; }
    .train-showcase-map .sig-top { fill: #505058; stroke: #353540; stroke-width: 0.75; stroke-linejoin: round; }
    .train-showcase-map .sig-inset { fill: #2a2a30; stroke: #252528; stroke-width: 0.5; }
    .train-showcase-map .sig-red { fill: #d44040; }
    .train-showcase-map .sig-off { fill: #585860; }

    .train-showcase-map .cx-post { stroke: #606068; stroke-width: 1.5; stroke-linecap: round; }
    .train-showcase-map .cx-box-left { fill: #404048; stroke: #353540; stroke-width: 0.3; stroke-linejoin: round; }
    .train-showcase-map .cx-box-right { fill: #4a4a52; stroke: #353540; stroke-width: 0.3; stroke-linejoin: round; }
    .train-showcase-map .cx-box-top { fill: #505058; stroke: #353540; stroke-width: 0.3; stroke-linejoin: round; }
    .train-showcase-map .cx-bar-rf { fill: #d44040; }
    .train-showcase-map .cx-bar-wf { fill: #e0e0e0; }
    .train-showcase-map .cx-bar-rt { fill: #e86060; }
    .train-showcase-map .cx-bar-wt { fill: #f0f0f0; }
    .train-showcase-map .cx-bar-end { fill: #b83030; }

    .train-showcase-map .rt-line { stroke-linecap: round; stroke-linejoin: round; fill: none; stroke-width: 0.6; }
    .train-showcase-map .rt-station { fill: #f0f0f0; stroke: #2a2a2a; stroke-width: 0.3; }

    .train-showcase-map .tk-tie-top { fill: #8a8280; }
    .train-showcase-map .tk-tie-front { fill: #6a6260; }
    .train-showcase-map .tk-tie-left { fill: #7a7270; }
    .train-showcase-map .tk-rail-top { fill: #c0b8b0; }
    .train-showcase-map .tk-rail-side { fill: #908880; }

    .train-showcase-map .train-overlay-swatch-trains {
        background: linear-gradient(180deg, rgba(219, 234, 254, 0.6), rgba(241, 245, 249, 0.8));
    }

    /* focus-visible ring for keyboard accessibility */

    .train-showcase-map .train-overlay-legend-item:focus-within .train-overlay-swatch-badge {
        outline: 2px solid #2563eb;
        outline-offset: 2px;
    }

    /* dark theme badge override */

    .sgb-map-container.sgb-map-dark .train-overlay-swatch-badge {
        border-color: var(--sgb-map-ctrl-bg);
    }

    .sgb-map-container.sgb-map-dark .train-overlay-legend-item[data-active="false"] .sgb-map-legend-item-label {
        color: #475569;
    }

    .sgb-map-container.sgb-map-dark .train-overlay-legend-item[data-active="false"] .sgb-map-legend-item-description {
        color: #334155;
    }
</style>

<div class="train-showcase-map">
    <SgbMap @ref="_map"
            MapOptions="@_mapOptions"
            Controls="@_controls"
            Images="@_images"
            Theme="@GlobalTheme"
            Height="600px"
            Width="100%">
        <MapLegend Definition="@OverlayLegendDefinition"
                   ControlId="overlay-legend"
                   OnItemVisibilityChanged="@HandleLegendItemVisibilityChangedAsync">
            <ItemTemplate Context="context">
                <label class="train-overlay-legend-item" data-active="@context.Visible.ToString().ToLowerInvariant()">
                    <span class="@GetOverlayLegendSwatchClassName(context.Item)" aria-hidden="true">
                        <span class="train-overlay-swatch-art">
                            @switch (context.Item.Id)
                            {
                                case "tracks":
                                    <svg class="train-overlay-swatch-svg" viewBox="98 120 104 64" aria-hidden="true">
                                        <g transform="translate(152, 152)">
                                            <polygon class="tk-tie-top" points="41.6,-14.5 20.8,-26.5 17.8,-24.8 38.5,-12.8" />
                                            <polygon class="tk-tie-front" points="38.5,-12.8 38.5,-10.2 17.8,-22.2 17.8,-24.8" />
                                            <polygon class="tk-tie-left" points="41.6,-14.5 41.6,-12.0 38.5,-10.2 38.5,-12.8" />
                                            <polygon class="tk-tie-top" points="33.8,-10.0 13.0,-22.0 10.0,-20.2 30.7,-8.2" />
                                            <polygon class="tk-tie-front" points="30.7,-8.2 30.7,-5.8 10.0,-17.8 10.0,-20.2" />
                                            <polygon class="tk-tie-left" points="33.8,-10.0 33.8,-7.5 30.7,-5.8 30.7,-8.2" />
                                            <polygon class="tk-tie-top" points="26.0,-5.5 5.2,-17.5 2.2,-15.8 22.9,-3.8" />
                                            <polygon class="tk-tie-front" points="22.9,-3.8 22.9,-1.2 2.2,-13.2 2.2,-15.8" />
                                            <polygon class="tk-tie-left" points="26.0,-5.5 26.0,-3.0 22.9,-1.2 22.9,-3.8" />
                                            <polygon class="tk-tie-top" points="18.2,-1.0 -2.6,-13.0 -5.6,-11.2 15.2,0.8" />
                                            <polygon class="tk-tie-front" points="15.2,0.8 15.2,3.2 -5.6,-8.8 -5.6,-11.2" />
                                            <polygon class="tk-tie-left" points="18.2,-1.0 18.2,1.5 15.2,3.2 15.2,0.8" />
                                            <polygon class="tk-tie-top" points="10.4,3.5 -10.4,-8.5 -13.4,-6.8 7.4,5.2" />
                                            <polygon class="tk-tie-front" points="7.4,5.2 7.4,7.8 -13.4,-4.2 -13.4,-6.8" />
                                            <polygon class="tk-tie-left" points="10.4,3.5 10.4,6.0 7.4,7.8 7.4,5.2" />
                                            <polygon class="tk-tie-top" points="2.6,8.0 -18.2,-4.0 -21.2,-2.2 -0.4,9.8" />
                                            <polygon class="tk-tie-front" points="-0.4,9.8 -0.4,12.2 -21.2,0.2 -21.2,-2.2" />
                                            <polygon class="tk-tie-left" points="2.6,8.0 2.6,10.5 -0.4,12.2 -0.4,9.8" />
                                            <polygon class="tk-tie-top" points="-5.2,12.5 -26.0,0.5 -29.0,2.2 -8.2,14.2" />
                                            <polygon class="tk-tie-front" points="-8.2,14.2 -8.2,16.8 -29.0,4.8 -29.0,2.2" />
                                            <polygon class="tk-tie-left" points="-5.2,12.5 -5.2,15.0 -8.2,16.8 -8.2,14.2" />
                                            <polygon class="tk-tie-top" points="-13.0,17.0 -33.8,5.0 -36.8,6.8 -16.0,18.8" />
                                            <polygon class="tk-tie-front" points="-16.0,18.8 -16.0,21.2 -36.8,9.2 -36.8,6.8" />
                                            <polygon class="tk-tie-left" points="-13.0,17.0 -13.0,19.5 -16.0,21.2 -16.0,18.8" />
                                            <polygon class="tk-tie-top" points="-20.8,21.5 -41.6,9.5 -44.6,11.2 -23.8,23.2" />
                                            <polygon class="tk-tie-front" points="-23.8,23.2 -23.8,25.8 -44.6,13.8 -44.6,11.2" />
                                            <polygon class="tk-tie-left" points="-20.8,21.5 -20.8,24.0 -23.8,25.8 -23.8,23.2" />
                                            <polygon class="tk-rail-side" points="36.5,-19.4 36.5,-17.4 -32.7,22.6 -32.7,20.6" />
                                            <polygon class="tk-rail-side" points="34.5,-20.6 34.5,-18.6 -34.8,21.4 -34.8,19.4" />
                                            <polygon class="tk-rail-side" points="36.5,-17.4 34.5,-18.6 -34.8,21.4 -32.7,22.6" />
                                            <polygon class="tk-rail-top" points="36.5,-19.4 34.5,-20.6 -34.8,19.4 -32.7,20.6" />
                                            <polygon class="tk-rail-side" points="27.9,-24.4 27.9,-22.4 -41.4,17.6 -41.4,15.6" />
                                            <polygon class="tk-rail-side" points="25.8,-25.6 25.8,-23.6 -43.5,16.4 -43.5,14.4" />
                                            <polygon class="tk-rail-side" points="27.9,-22.4 25.8,-23.6 -43.5,16.4 -41.4,17.6" />
                                            <polygon class="tk-rail-top" points="27.9,-24.4 25.8,-25.6 -43.5,14.4 -41.4,15.6" />
                                        </g>
                                    </svg>
                                    break;
                                case "tram":
                                    <svg class="train-overlay-swatch-svg" viewBox="0 0 44 44" aria-hidden="true">
                                        <!-- tram-stop sprite: red rounded square -->
                                        <rect x="8" y="16" width="12" height="12" rx="3" ry="3" fill="#dc2626" stroke="#ffffff" stroke-width="1.5" />
                                        <!-- subway-entrance sprite: blue triangle -->
                                        <polygon points="30,16 36,28 24,28" fill="#1d4ed8" stroke="#ffffff" stroke-width="1.5" stroke-linejoin="round" />
                                    </svg>
                                    break;
                                case "stations":
                                    <svg class="train-overlay-swatch-svg" viewBox="0 0 44 44" aria-hidden="true">
                                        <circle cx="15" cy="22" fill="#c2410c" stroke="#fff" stroke-width="1.5" r="5" />
                                        <circle cx="30" cy="22" fill="#fff" stroke="#1e293b" stroke-width="1.5" r="5" />
                                    </svg>
                                    break;
                                case "platforms":
                                    <svg class="train-overlay-swatch-svg" viewBox="0 0 44 44" aria-hidden="true">
                                        <g transform="translate(17.5, 25)">
                                            <polygon class="p-left" points="-9,-1.5 0,3 0,4.2 -9,-0.3" />
                                            <polygon class="p-right" points="0,3 9,-1.5 9,-0.3 0,4.2" />
                                            <polygon class="p-right" points="9,-1.5 18,-6 18,-4.8 9,-0.3" />
                                            <polygon class="p-roof" points="-9,-1.5 0,3 9,-1.5 18,-6 9,-10.5 0,-6" />
                                        </g>
                                    </svg>
                                    break;
                                case "routes":
                                    <svg class="train-overlay-swatch-svg" viewBox="12.5 15 18 12" aria-hidden="true">
                                        <g transform="translate(22, 22) rotate(-5)">
                                            <!-- bundled corridor between stations -->
                                            <polygon points="-4,2 4,-2 4,-2.7 -4,1.3" fill="#e03030" />
                                            <polygon points="-4,1.3 4,-2.7 4,-3.4 -4,0.6" fill="#3080d0" />
                                            <polygon points="-4,0.6 4,-3.4 4,-4.1 -4,-0.1" fill="#eab308" />
                                            <!-- blue: straight through both stations -->
                                            <path class="rt-line" d="M-7,2.6 L-4,1.3" stroke="#3080d0" />
                                            <path class="rt-line" d="M4,-2.7 L7,-4" stroke="#3080d0" />
                                            <!-- left side: red/green fan from left station -->
                                            <path class="rt-line" d="M-4,1.3 L-6.5,0.5" stroke="#e03030" />
                                            <path class="rt-line" d="M-4,1.3 L-4.9,3.8" stroke="#eab308" />
                                            <!-- right side: red/green fan from right station -->
                                            <path class="rt-line" d="M4,-2.7 L6.5,-1.9" stroke="#e03030" />
                                            <path class="rt-line" d="M4,-2.7 L4.9,-5.2" stroke="#eab308" />
                                            <!-- stations -->
                                            <circle class="rt-station" cx="-4" cy="1.3" r="1.2" />
                                            <circle class="rt-station" cx="4" cy="-2.7" r="1.2" />
                                        </g>
                                    </svg>
                                    break;
                                case "lifecycle":
                                    <svg class="train-overlay-swatch-svg" viewBox="0 0 44 44" aria-hidden="true">
                                        <line x1="6" y1="16" x2="38" y2="16" stroke="#d97706" stroke-width="2" stroke-dasharray="4 3" stroke-linecap="round" />
                                        <line x1="6" y1="28" x2="38" y2="28" stroke="#94a3b8" stroke-width="2" stroke-dasharray="4 3" stroke-linecap="round" />
                                    </svg>
                                    break;
                                case "infrastructure":
                                    <svg class="train-overlay-swatch-svg" viewBox="0 0 44 44" aria-hidden="true">
                                        <g transform="translate(22, 30)">
                                            <line class="sig-post" x1="0" y1="18" x2="0" y2="-8" />
                                            <g transform="translate(1.2, 0)">
                                                <polygon class="sig-head" points="-6,-7 0,-3.5 0,-21 -6,-24.5" />
                                                <polygon class="sig-head" points="0,-3.5 2.5,-5.2 2.5,-22.7 0,-21" />
                                                <polygon class="sig-top" points="-6,-24.5 0,-21 2.5,-22.7 -3.5,-26.2" />
                                                <g transform="translate(-3, -17.5)">
                                                    <ellipse class="sig-inset" cx="0" cy="0" rx="2.4" ry="2.4" transform="scale(0.5, 1) rotate(-30)" />
                                                    <ellipse class="sig-red" cx="0" cy="0" rx="1.7" ry="1.7" transform="scale(0.5, 1) rotate(-30)" />
                                                </g>
                                                <g transform="translate(-3, -10)">
                                                    <ellipse class="sig-inset" cx="0" cy="0" rx="2.4" ry="2.4" transform="scale(0.5, 1) rotate(-30)" />
                                                    <ellipse class="sig-off" cx="0" cy="0" rx="1.7" ry="1.7" transform="scale(0.5, 1) rotate(-30)" />
                                                </g>
                                            </g>
                                        </g>
                                    </svg>
                                    break;
                                case "3d-buildings":
                                    <svg class="train-overlay-swatch-svg" viewBox="0 0 44 44" aria-hidden="true">
                                        <g transform="translate(22, 20)">
                                            <polygon class="b-left" points="-14,4 0,11 0,7 -14,0" />
                                            <polygon class="b-right" points="0,11 14,4 14,0 0,7" />
                                            <polygon class="b-roof" points="-14,0 0,7 14,0 0,-7" />
                                        </g>
                                    </svg>
                                    break;
                                case "trains":
                                    <svg class="train-overlay-swatch-svg" viewBox="-4 -4 40 40" aria-hidden="true">
                                        <g transform="translate(16, 16) rotate(-30)">
                                            <path d="M27.5 16C24.5 12.5 19 7.8 13.2 7.8C7.5 7.8 4.5 11.8 4.5 16C4.5 20.2 7.5 24.2 13.2 24.2C19 24.2 24.5 19.5 27.5 16Z" fill="#2563eb" stroke="white" stroke-width="2" stroke-linejoin="round" transform="translate(-16, -16)" />
                                        </g>
                                    </svg>
                                    break;
                            }
                        </span>
                        <span class="train-overlay-swatch-badge"></span>
                    </span>
                    <span class="train-overlay-legend-copy">
                        <span class="sgb-map-legend-item-label">@context.Item.Label</span>
                        @if (!string.IsNullOrWhiteSpace(context.Item.Description))
                        {
                            <span class="sgb-map-legend-item-description">@context.Item.Description</span>
                        }
                    </span>
                    <input type="checkbox"
                           data-testid="@($"map-legend-toggle-{context.Item.Id}")"
                           checked="@context.Visible"
                           @onchange="@(async args => await context.SetVisibilityAsync(ResolveLegendToggleValue(args)))" />
                </label>
            </ItemTemplate>
        </MapLegend>

        <FillExtrusionLayer Id="sgb-buildings-3d"
                            SourceId="openmaptiles"
                            SourceLayer="building"
                            Color="@("#d1d5db")"
                            Opacity="0.7"
                            Height="@(Expr.Get("render_height"))"
                            Base="@(Expr.Get("render_min_height"))"
                            MinZoom="14"
                            Visible="@_visibility.ShowBuildings" />

        <TrackedDataSource TItem="TrainSampleState"
                           @ref="_trainSource"
                           SourceId="train-source"
                           Items="@_trains"
                           Id="@_trainId"
                           Symbol="@_trainSymbol"
                           Decorations="@_trainDecorations"
                           Cluster="@_trainClusterOptions"
                           Interaction="@_trainInteraction"
                           Animation="@_trainAnimation"
                           Visible="@_visibility.ShowTrains"
                           PrimaryIconOpacity="@_trainIconOpacityExpr"
                           OnItemClick="@HandleTrainClick"
                           OnItemMouseEnter="@HandleTrainHover"
                           OnItemMouseLeave="@HandleTrainLeave" />

    </SgbMap>
</div>
