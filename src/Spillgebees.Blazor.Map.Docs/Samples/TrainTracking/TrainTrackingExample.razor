@using Spillgebees.Blazor.Map.Components
@using Spillgebees.Blazor.Map.Components.Layers
@using Spillgebees.Blazor.Map.Models
@using Spillgebees.Blazor.Map.Models.Events
@using Spillgebees.Blazor.Map.Models.Expressions
@using Spillgebees.Blazor.Map.Models.Legends
@using Spillgebees.Blazor.Map.Models.TrackedData
@using Spillgebees.Blazor.Map.Models.TrackedEntities
@using Spillgebees.Blazor.Map.Docs.Samples.TrainTracking

<style>
    @@import url("https://fonts.googleapis.com/css2?family=Martian+Mono:wght@400&family=DM+Sans:wght@400;500;600;700&display=swap");

    .train-showcase-map {
        overflow: hidden;
        border-radius: 22px;
        border: 1px solid rgba(148, 163, 184, 0.25);
        background: rgba(255, 255, 255, 0.88);
        backdrop-filter: blur(10px);
    }

    /* legend layout */

    .train-showcase-map .sgb-map-legend-content {
        font-family: "DM Sans", sans-serif;
        font-size: 14px;
        line-height: 1.4;
    }

    .train-showcase-map .sgb-map-legend-section-title {
        font-family: "Martian Mono", monospace;
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        font-weight: 400;
    }

    .train-showcase-map .sgb-map-legend-title {
        font-family: "DM Sans", sans-serif;
        font-size: 15px;
        font-weight: 700;
        letter-spacing: -0.01em;
    }

    .train-showcase-map .train-overlay-legend-content {
        gap: 12px;
    }

    .train-showcase-map .train-overlay-legend-item {
        display: grid;
        grid-template-columns: 44px minmax(0, 1fr);
        gap: 10px;
        align-items: center;
        padding: 8px;
        border-radius: 12px;
        cursor: pointer;
        transition: background 0.15s;
        user-select: none;
    }

    .train-showcase-map .train-overlay-legend-item:hover {
        background: var(--sgb-map-ctrl-bg-hover);
    }

    .train-showcase-map .train-overlay-legend-copy {
        display: grid;
        gap: 2px;
        min-width: 0;
    }

    /* swatch container */

    .train-showcase-map .train-overlay-swatch {
        position: relative;
        display: grid;
        place-items: center;
        width: 44px;
        height: 44px;
        border-radius: 10px;
    }

    .train-showcase-map .train-overlay-swatch-art {
        position: absolute;
        inset: 0;
        border-radius: inherit;
        overflow: hidden;
        transition: opacity 0.25s, filter 0.25s;
    }

    .train-showcase-map .train-overlay-swatch-art > span {
        position: absolute;
    }

    /* checkbox badge */

    .train-showcase-map .train-overlay-swatch-badge {
        position: absolute;
        bottom: -2px;
        right: -2px;
        width: 16px;
        height: 16px;
        border-radius: 999px;
        background: #2563eb;
        border: 2px solid #fff;
        z-index: 2;
        display: grid;
        place-items: center;
        will-change: transform;
        backface-visibility: hidden;
        transition: background 0.2s, transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .train-showcase-map .train-overlay-swatch-badge::before,
    .train-showcase-map .train-overlay-swatch-badge::after {
        content: "";
        position: absolute;
        transition: opacity 0.15s;
    }

    /* checkmark (visible when active) */
    .train-showcase-map .train-overlay-swatch-badge::after {
        width: 6px;
        height: 3px;
        margin-top: -1px;
        border-left: 1.5px solid #fff;
        border-bottom: 1.5px solid #fff;
        transform: rotate(-45deg);
    }

    /* cross arm 1 (visible when inactive) */
    .train-showcase-map .train-overlay-swatch-badge::before {
        width: 7px;
        height: 1.5px;
        background: #fff;
        border-radius: 1px;
        transform: rotate(45deg);
        opacity: 0;
    }

    .train-showcase-map .train-overlay-legend-item input {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
    }

    /* disabled / off state */

    .train-showcase-map .train-overlay-legend-item[data-active="false"] .sgb-map-legend-item-label {
        color: #94a3b8;
    }

    .train-showcase-map .train-overlay-legend-item[data-active="false"] .sgb-map-legend-item-description {
        color: #cbd5e1;
    }

    .train-showcase-map .train-overlay-legend-item[data-active="false"] .train-overlay-swatch-badge {
        background: #94a3b8;
    }

    /* hide checkmark, show cross */
    .train-showcase-map .train-overlay-legend-item[data-active="false"] .train-overlay-swatch-badge::after {
        width: 7px;
        height: 1.5px;
        margin-top: 0;
        border: none;
        background: #fff;
        border-radius: 1px;
        transform: rotate(-45deg);
    }

    .train-showcase-map .train-overlay-legend-item[data-active="false"] .train-overlay-swatch-badge::before {
        opacity: 1;
    }

    /* swatch backgrounds */

    .train-showcase-map .train-overlay-swatch-stations,
    .train-showcase-map .train-overlay-swatch-platforms,
    .train-showcase-map .train-overlay-swatch-routes,
    .train-showcase-map .train-overlay-swatch-tracks,
    .train-showcase-map .train-overlay-swatch-tram,
    .train-showcase-map .train-overlay-swatch-lifecycle,
    .train-showcase-map .train-overlay-swatch-infrastructure {
        background: linear-gradient(180deg, rgba(241, 245, 249, 0.9), rgba(226, 232, 240, 0.7));
    }

    .train-showcase-map .train-overlay-swatch-3d-buildings {
        background: linear-gradient(180deg, rgba(241, 245, 249, 0.9), rgba(226, 232, 240, 0.7));
    }

    /* inline SVG swatch */
    .train-showcase-map .train-overlay-swatch-svg {
        width: 100%;
        height: 100%;
    }

    .train-showcase-map .b-roof { fill: #d4d6d9; stroke: #b8babe; stroke-width: 0.5; }
    .train-showcase-map .b-left { fill: #a8aab0; stroke: #9a9ca2; stroke-width: 0.5; }
    .train-showcase-map .b-right { fill: #bcbec4; stroke: #9a9ca2; stroke-width: 0.5; }

    .train-showcase-map .p-roof { fill: #c4b8e8; stroke: #a090d0; stroke-width: 0.5; }
    .train-showcase-map .p-left { fill: #9888c0; }
    .train-showcase-map .p-right { fill: #b0a0d8; }

    .train-showcase-map .sig-post { stroke: #606068; stroke-width: 3; stroke-linecap: round; }
    .train-showcase-map .sig-head { fill: #404048; stroke: #353540; stroke-width: 0.75; stroke-linejoin: round; }
    .train-showcase-map .sig-top { fill: #505058; stroke: #353540; stroke-width: 0.75; stroke-linejoin: round; }
    .train-showcase-map .sig-inset { fill: #2a2a30; stroke: #252528; stroke-width: 0.5; }
    .train-showcase-map .sig-red { fill: #d44040; }
    .train-showcase-map .sig-off { fill: #585860; }

    .train-showcase-map .cx-post { stroke: #606068; stroke-width: 1.5; stroke-linecap: round; }
    .train-showcase-map .cx-box-left { fill: #404048; stroke: #353540; stroke-width: 0.3; stroke-linejoin: round; }
    .train-showcase-map .cx-box-right { fill: #4a4a52; stroke: #353540; stroke-width: 0.3; stroke-linejoin: round; }
    .train-showcase-map .cx-box-top { fill: #505058; stroke: #353540; stroke-width: 0.3; stroke-linejoin: round; }
    .train-showcase-map .cx-bar-rf { fill: #d44040; }
    .train-showcase-map .cx-bar-wf { fill: #e0e0e0; }
    .train-showcase-map .cx-bar-rt { fill: #e86060; }
    .train-showcase-map .cx-bar-wt { fill: #f0f0f0; }
    .train-showcase-map .cx-bar-end { fill: #b83030; }

    .train-showcase-map .rt-line { stroke-linecap: round; stroke-linejoin: round; fill: none; stroke-width: 0.6; }
    .train-showcase-map .rt-station { fill: #f0f0f0; stroke: #2a2a2a; stroke-width: 0.3; }

    .train-showcase-map .tk-tie-top { fill: #8a8280; }
    .train-showcase-map .tk-tie-front { fill: #6a6260; }
    .train-showcase-map .tk-tie-left { fill: #7a7270; }
    .train-showcase-map .tk-rail-top { fill: #c0b8b0; }
    .train-showcase-map .tk-rail-side { fill: #908880; }

    .train-showcase-map .train-overlay-swatch-trains {
        background: linear-gradient(180deg, rgba(219, 234, 254, 0.6), rgba(241, 245, 249, 0.8));
    }

    /* focus-visible ring for keyboard accessibility */

    .train-showcase-map .train-overlay-legend-item:focus-within .train-overlay-swatch-badge {
        outline: 2px solid #2563eb;
        outline-offset: 2px;
    }

    /* dark theme badge override */

    .sgb-map-container.sgb-map-dark .train-overlay-swatch-badge {
        border-color: var(--sgb-map-ctrl-bg);
    }

    .sgb-map-container.sgb-map-dark .train-overlay-legend-item[data-active="false"] .sgb-map-legend-item-label {
        color: #475569;
    }

    .sgb-map-container.sgb-map-dark .train-overlay-legend-item[data-active="false"] .sgb-map-legend-item-description {
        color: #334155;
    }
</style>

<div class="train-showcase-map">
    <SgbMap @ref="_map"
            MapOptions="@_mapOptions"
            Controls="@BuildControls()"
            Images="@_images"
            TrackedDataLayers="@_trackedDataLayers"
            Theme="@GlobalTheme"
            Height="600px"
            Width="100%">
        <FillExtrusionLayer Id="sgb-buildings-3d"
                            SourceId="openmaptiles"
                            SourceLayer="building"
                            Color="@("#d1d5db")"
                            Opacity="0.7"
                            Height="@(Expr.Get("render_height"))"
                            Base="@(Expr.Get("render_min_height"))"
                            MinZoom="14"
                            Visible="@_visibility.ShowBuildings" />

    </SgbMap>
</div>

@code {
    private IReadOnlyList<MapControl> BuildControls() =>
    [
        new NavigationMapControl(),
        new LegendMapControl(
            "overlay-legend",
            new MapControlPlacement(ControlPosition.TopLeft, 500, Enabled: true),
            new LegendChromeOptions("Legend", Collapsible: true, InitiallyOpen: true, ClassName: null),
            new LegendContentOptions(
                TrainTrackingPresentation.OverlayLegendDefinition,
                OverlayLegendItemTemplate,
                EventCallback.Factory.Create<MapLegendVisibilityChangedEventArgs>(
                    this,
                    HandleLegendItemVisibilityChangedAsync
                )
            )
        ),
    ];

    private RenderFragment<MapLegendItemTemplateContext> OverlayLegendItemTemplate => context => @<label class="train-overlay-legend-item" data-active="@context.Selected.ToString().ToLowerInvariant()">
            <span class="@GetOverlayLegendSwatchClassName(context.Item)" aria-hidden="true">
                <span class="train-overlay-swatch-art">
                    @switch (context.Item.Id)
                    {
                        case "tracks":
                            <svg class="train-overlay-swatch-svg" viewBox="0 0 44 44" aria-hidden="true">
                                <rect class="tk-rail-top" x="6" y="18" width="32" height="3" />
                                <rect class="tk-tie-top" x="10" y="24" width="24" height="2" />
                            </svg>
                            break;
                        case "tram":
                            <svg class="train-overlay-swatch-svg" viewBox="0 0 44 44" aria-hidden="true">
                                <rect x="8" y="16" width="12" height="12" rx="3" ry="3" fill="#dc2626" stroke="#ffffff" stroke-width="1.5" />
                                <polygon points="30,16 36,28 24,28" fill="#1d4ed8" stroke="#ffffff" stroke-width="1.5" stroke-linejoin="round" />
                            </svg>
                            break;
                        case "stations":
                            <svg class="train-overlay-swatch-svg" viewBox="0 0 44 44" aria-hidden="true">
                                <circle cx="15" cy="22" fill="#c2410c" stroke="#fff" stroke-width="1.5" r="5" />
                                <circle cx="30" cy="22" fill="#fff" stroke="#1e293b" stroke-width="1.5" r="5" />
                            </svg>
                            break;
                        case "platforms":
                            <svg class="train-overlay-swatch-svg" viewBox="0 0 44 44" aria-hidden="true">
                                <polygon class="p-roof" points="12,26 22,20 32,26 22,32" />
                            </svg>
                            break;
                        case "routes":
                            <svg class="train-overlay-swatch-svg" viewBox="0 0 44 44" aria-hidden="true">
                                <path class="rt-line" d="M8,26 L36,18" stroke="#3080d0" />
                                <circle class="rt-station" cx="16" cy="24" r="2" />
                                <circle class="rt-station" cx="30" cy="20" r="2" />
                            </svg>
                            break;
                        case "lifecycle":
                            <svg class="train-overlay-swatch-svg" viewBox="0 0 44 44" aria-hidden="true">
                                <line x1="6" y1="16" x2="38" y2="16" stroke="#d97706" stroke-width="2" stroke-dasharray="4 3" stroke-linecap="round" />
                                <line x1="6" y1="28" x2="38" y2="28" stroke="#94a3b8" stroke-width="2" stroke-dasharray="4 3" stroke-linecap="round" />
                            </svg>
                            break;
                        case "infrastructure":
                            <svg class="train-overlay-swatch-svg" viewBox="0 0 44 44" aria-hidden="true">
                                <line class="sig-post" x1="22" y1="32" x2="22" y2="10" />
                                <circle class="sig-red" cx="22" cy="16" r="3" />
                            </svg>
                            break;
                        case "3d-buildings":
                            <svg class="train-overlay-swatch-svg" viewBox="0 0 44 44" aria-hidden="true">
                                <polygon class="b-roof" points="10,22 22,14 34,22 22,30" />
                            </svg>
                            break;
                        case "trains":
                            <svg class="train-overlay-swatch-svg" viewBox="0 0 44 44" aria-hidden="true">
                                <path d="M36 22C32 18 26 14 20 14C14 14 10 18 10 22C10 26 14 30 20 30C26 30 32 26 36 22Z" fill="#2563eb" stroke="white" stroke-width="2" stroke-linejoin="round" />
                            </svg>
                            break;
                    }
                </span>
                <span class="train-overlay-swatch-badge"></span>
            </span>
            <span class="train-overlay-legend-copy">
                <span class="sgb-map-legend-item-label">@context.Item.Label</span>
                @if (!string.IsNullOrWhiteSpace(context.Item.Description))
                {
                    <span class="sgb-map-legend-item-description">@context.Item.Description</span>
                }
            </span>
            <input type="checkbox"
                   data-testid="@($"map-legend-toggle-{context.Item.Id}")"
                   checked="@context.Selected"
                   @onchange="@(async args => await context.SetSelectedAsync(ResolveLegendToggleValue(args)))" />
        </label>;

    private static bool ResolveLegendToggleValue(ChangeEventArgs args) =>
        args.Value switch
        {
            bool boolValue => boolValue,
            string stringValue when bool.TryParse(stringValue, out var parsed) => parsed,
            _ => false,
        };

    private static string GetOverlayLegendSwatchClassName(MapLegendItemDefinition item) =>
        $"train-overlay-swatch train-overlay-swatch-{item.Id}";
}
