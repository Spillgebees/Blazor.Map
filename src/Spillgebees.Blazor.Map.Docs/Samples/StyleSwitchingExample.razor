<div class="sample-btn-row">
    <button type="button" class="sample-btn @(_activeStyle == "liberty" ? "active" : "")" aria-pressed="@(_activeStyle == "liberty")" @onclick="@(() => SetStyle("liberty", MapStyle.OpenFreeMap.Liberty))">Liberty</button>
    <button type="button" class="sample-btn @(_activeStyle == "positron" ? "active" : "")" aria-pressed="@(_activeStyle == "positron")" @onclick="@(() => SetStyle("positron", MapStyle.OpenFreeMap.Positron))">Positron</button>
    <button type="button" class="sample-btn @(_activeStyle == "bright" ? "active" : "")" aria-pressed="@(_activeStyle == "bright")" @onclick="@(() => SetStyle("bright", MapStyle.OpenFreeMap.Bright))">Bright</button>
</div>

<SgbMap MapOptions="@_mapOptions"
        ControlOptions="@MapControlOptions.Default"
        Height="400px"
        Width="100%" />

@code {
    private string _activeStyle = "liberty";

    private MapOptions _mapOptions = new(
        Center: new Coordinate(49.75, 6.10),
        Zoom: 9,
        Style: MapStyle.OpenFreeMap.Liberty
    );

    private void SetStyle(string key, MapStyle style)
    {
        _activeStyle = key;
        _mapOptions = _mapOptions with { Style = style };
    }
}
