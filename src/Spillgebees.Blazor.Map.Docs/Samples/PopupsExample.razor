<SgbMap MapOptions="@_mapOptions"
        Markers="@_markers"
        Height="400px"
        Width="100%">
    <MapControls>
        <MapNavigationControl />
    </MapControls>
    <MapOverlays>
        <MapPopup Id="component-popup" Position="@(new Coordinate(49.6160, 6.1250))">
            <button type="button" class="sample-btn" @onclick="IncrementClicks">Blazor popup clicks: @_clicks</button>
        </MapPopup>
    </MapOverlays>
</SgbMap>

<p><strong>Raw HTML warning:</strong> use <code>PopupOptions.FromRawHtml</code> only with trusted or sanitized HTML.</p>

@code {
    private readonly MapOptions _mapOptions = new(
        Center: new Coordinate(49.6117, 6.1319),
        Zoom: 12
    );

    private readonly List<Marker> _markers =
    [
        new(
            "marker-click",
            new Coordinate(49.6000, 6.1100),
            Title: "Click popup",
            Popup: PopupOptions.FromText(
                "Safe text default: <strong>markup displays as text</strong>",
                PopupTrigger.Click
            )
        ),
        new(
            "marker-hover",
            new Coordinate(49.6117, 6.1319),
            Title: "Hover popup",
            Popup: PopupOptions.FromRawHtml(
                "<strong>Hover popup</strong><br>Hover over the marker to open this popup.",
                PopupTrigger.Hover
            )
        ),
        new(
            "marker-permanent",
            new Coordinate(49.6230, 6.1500),
            Title: "Permanent popup",
            Popup: PopupOptions.FromRawHtml(
                "<strong>Permanent popup</strong><br>This popup is always visible.",
                PopupTrigger.Permanent,
                closeButton: false
            )
        )
    ];

    private int _clicks;

    private void IncrementClicks()
    {
        _clicks++;
    }
}
