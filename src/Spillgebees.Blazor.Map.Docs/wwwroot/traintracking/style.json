    },
    {
      "id": "railway-areas-fill",
      "type": "fill",
      "source": "railway",
      "layout": {
        "visibility": "none"
      },
      "paint": {
        "fill-color": "#f5f0e8",
        "fill-opacity": 0.3
      }
    },
    {
      "id": "railway-areas-outline",
