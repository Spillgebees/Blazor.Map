      "paint": {
        "line-color": "#d6cebe",
        "line-width": 1,
        "line-opacity": 0.4
      }
    },
    {
      "id": "railway-line-main",
      "type": "line",
      "source": "railway",
      "filter": ["all", ["!=", ["get", "railway"], "tram"], ["==", ["get", "service"], ""]],
      "layout": {
        "visibility": "none",
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#334155",
        "line-width": 2
      }
    },
    {
